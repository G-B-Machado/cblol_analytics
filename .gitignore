# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C++ extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
